---
import ProjectCardV2 from "@components/Project/ProjectCardV2.astro";
import type { ProjectEntry } from "@utils/interfaces";
import { toSlug } from "@utils/index";
import { SectionHeaderStandard } from "@walle/components";
import { BaseLayout } from "@walle/layouts";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const allProjects = await getCollection("project");

  const byCategory = allProjects.reduce<Record<string, typeof allProjects>>((acc, project) => {
    const key = project.data.category;
    if (!acc[key]) acc[key] = [];
    acc[key].push(project);
    return acc;
  }, {});

  return Object.entries(byCategory)
    .filter(([, projects]) => projects.length >= 2)
    .map(([category, projects]) => ({
      params: { category: toSlug(category) },
      props: { category, projects },
    }));
}

interface Props {
  category: string;
  projects: ProjectEntry[];
}

const { category, projects } = Astro.props;
---

<BaseLayout
  headerTitle={`${category} open source projects | European Open Source`}
  headerDescription={`Discover ${projects.length} European open-source projects in the ${category} category.`}
>
  <SectionHeaderStandard
    title={`${category} projects`}
    subtitle={`${projects.length} European open-source project${projects.length !== 1 ? "s" : ""} in the ${category} category.`}
    effect={true}
  />

  <section class="category-projects-section">
    <div class="container">
      <div class="projects-grid">
        {
          projects.map((project: ProjectEntry) => (
            <ProjectCardV2 {...project.data} projectDetailUrl={`/projects/${project.id}`} />
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .category-projects-section {
    padding: var(--space-xl) 0 var(--space-4xl);
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-lg);
  }
</style>
