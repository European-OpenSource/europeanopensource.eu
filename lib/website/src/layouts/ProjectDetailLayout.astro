---
import ProjectCardDetail from "@components/Project/ProjectCardDetail.astro";
import type { Project } from "@utils/interfaces";
import { Badge, Breadcrumbs, Button, SectionHeaderStandard } from "@walle/components";
import config from "@walle/config";
import { BaseLayout } from "@walle/layouts";
import { Icon } from "astro-icon/components";

interface Props extends Project {}

const data = Astro.props;

const breadcrumbItems = [
  { label: "Home", url: "/" },
  { label: "Projects", url: "/projects" },
  { label: data.name },
];
---

<BaseLayout headerTitle={data.name} headerDescription={data.description}>
  <SectionHeaderStandard title={data.name} effect={true}>
    <div class="project-detail-badges">
      <Badge text={`${data.category.toLocaleUpperCase()}`} color="primary" size="large" />
      <Badge text={data.country} color="secondary" size="large" />
    </div>
  </SectionHeaderStandard>

  <section class="project-detail-section">
    <div class="container">
      <Breadcrumbs items={breadcrumbItems} />

      <div class="project-detail-container">
        <div class="project-detail-main">
          <ProjectCardDetail {...data} />
          <slot />
        </div>

        <aside class="project-detail-sidebar">
          {
            data.owner && (
              <div class="sidebar-card owner-card">
                <div class="sidebar-card__header">Owner</div>

                <div class="owner-identity">
                  <span class="owner-name">{data.owner.name}</span>
                  <div class="owner-chips">
                    <Badge text={data.owner.type.toUpperCase()} size="small" />
                    {data.owner.is_a_startup && (
                      <span class="startup-chip">
                        <Icon name="fa:rocket" />
                        Startup
                      </span>
                    )}
                  </div>
                </div>

                {data.owner.description && <p class="owner-desc">{data.owner.description}</p>}

                {data.owner.url_website && (
                  <div class="owner-footer">
                    <Button
                      link={data.owner.url_website}
                      target="_blank"
                      text="Visit Website"
                      iconName="fa:external-link"
                      type="secondary"
                      outline={true}
                      size="small"
                      fullWidth={true}
                    />
                  </div>
                )}
              </div>
            )
          }

          <div class="sidebar-card">
            <div class="sidebar-card__header">Resources</div>
            <ul class="resources-list">
              <li>
                <a
                  href={`${config.app.website.github_awesome_project_url}/blob/main/awesome/projects/${data.metadata.filename}`}
                  class="resource-link"
                  target="_blank"
                >
                  <Icon name="fa:folder-o" />
                  <span>Raw data</span>
                </a>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .project-detail-section {
    padding: var(--space-xl) 0 var(--space-4xl);
  }

  .project-detail-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    align-items: center;
  }

  .project-detail-container {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(0, 1fr);
    gap: var(--space-2xl);
    align-items: start;
    margin-top: var(--space-md);
  }

  .project-detail-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .project-detail-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  /* Sidebar cards */
  .sidebar-card {
    border-radius: var(--radius-lg);
    border: 1px solid var(--gray);
    overflow: hidden;
    background: var(--white);
  }

  .sidebar-card__header {
    padding: var(--space-sm) var(--space-lg);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--gray-dark);
    background: var(--gray-light);
    border-bottom: 1px solid var(--gray);
  }

  .sidebar-card__body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  /* Owner card — three distinct zones */
  .owner-identity {
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--gray);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .owner-name {
    font-weight: 700;
    color: var(--primary-dark);
    font-size: 1rem;
    line-height: 1.3;
  }

  .owner-chips {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }

  .startup-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: var(--alternative-dark);
    font-weight: 600;
    font-size: 0.75rem;
    background: rgba(255, 204, 0, 0.15);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-sm);
  }

  .owner-desc {
    padding: var(--space-md) var(--space-lg);
    font-size: 0.9rem;
    color: var(--gray-dark);
    line-height: 1.6;
    margin: 0;
  }

  .owner-footer {
    padding: var(--space-md) var(--space-lg);
    border-top: 1px solid var(--gray);
  }

  /* Resources */
  .resources-list {
    list-style: none;
    padding: var(--space-sm) var(--space-md);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .resource-link {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--primary);
    font-size: 0.9rem;
    font-weight: 500;
    padding: var(--space-xs) var(--space-sm);
    border-radius: var(--radius-sm);
    transition: all var(--transition);
    text-decoration: none;
  }

  .resource-link:hover {
    background: rgba(0, 70, 173, 0.06);
    color: var(--primary-dark);
    transform: translateX(2px);
  }

  /* ─── Responsive ─────────────────────────────────────── */

  /* Tablet: sidebar va affianco, sotto la main column */
  @media (max-width: 900px) {
    .project-detail-container {
      grid-template-columns: 1fr;
    }

    .project-detail-sidebar {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-lg);
    }
  }

  /* Mobile: tutto in colonna singola */
  @media (max-width: 580px) {
    .project-detail-section {
      padding: var(--space-lg) 0 var(--space-3xl);
    }

    .project-detail-container {
      margin-top: var(--space-sm);
    }

    .project-detail-sidebar {
      grid-template-columns: 1fr;
    }

    .owner-identity,
    .owner-desc,
    .owner-footer {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
    }

    .sidebar-card__header {
      padding-left: var(--space-md);
      padding-right: var(--space-md);
    }

    .resources-list {
      padding-left: var(--space-sm);
      padding-right: var(--space-sm);
    }
  }
</style>
